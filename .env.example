# Tento soubor je VZOR — nikdy sem nepište skutečné hodnoty.
# Skutečné hodnoty nastavte v Cloudflare Worker jako secrets (viz SETUP.md).

# Google Service Account
GOOGLE_CLIENT_EMAIL=muj-service-account@muj-projekt.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nVASE_HODNOTA\n-----END PRIVATE KEY-----

# Google Sheets
SHEETS_ID=1ABC...XYZ   # ID vašeho Google Sheets dokumentu

# Session bezpečnost — náhodný dlouhý řetězec
AUTH_SECRET=nahodny-dlouhy-retezec-min-32-znaku

# Hesla auditorek (JSON objekt: ID auditorky → hash hesla)
# Hash vygenerujte pomocí: node worker/generate-hash.mjs vase-heslo
AUDITORKA_PASSWORDS={"1":"pbkdf2:sůl:hash","2":"pbkdf2:sůl:hash"}

# E-mailová brána — Brevo (potvrzovací e-maily + .ics pozvánka, viz SETUP.md krok 4)
# Vygenerujte v Brevo: Nastavení → SMTP & API → API Keys → Generate new API Key
BREVO_API_KEY=xkeysib-vas-api-klic

# CORS — URL vašeho webu na Cloudflare Pages
ALLOWED_ORIGIN=https://rezervace-pohovory.pages.dev
